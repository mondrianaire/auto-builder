// Firestore Security Rules for GTO Duel
//
// Paste the contents of this file into your Firebase project's Firestore
// Rules tab (Firebase Console > Firestore Database > Rules) and click
// Publish. Tighter than the default test rules — only the two players in a
// game may read or write its document, and a third player cannot join.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // games/{gameId}: one document per game; gameId equals the share code.
    match /games/{gameId} {

      // Only authenticated (anonymous-auth-bound) users can interact.
      // Read: only the two participants. We use the participantUids array
      // because Firestore Rules can evaluate array membership cheaply.
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participantUids;

      // Create: the creator must (a) be authenticated, (b) include
      // themselves as the first participant, (c) start with exactly one
      // participant, (d) status = 'waiting_for_opponent'.
      allow create: if request.auth != null
                    && request.resource.data.participantUids.size() == 1
                    && request.resource.data.participantUids[0] == request.auth.uid
                    && request.resource.data.status == 'waiting_for_opponent';

      // Update: only existing participants can update. If a new participant
      // is being added (join), the resulting array must have exactly two
      // entries and the new one must be the requester. Status transitions
      // are constrained: 'waiting_for_opponent' -> 'in_progress' on join;
      // 'in_progress' -> 'in_progress' or 'complete' during play.
      allow update: if request.auth != null
                    && (request.auth.uid in resource.data.participantUids
                        || (resource.data.participantUids.size() == 1
                            && request.resource.data.participantUids.size() == 2
                            && request.auth.uid in request.resource.data.participantUids));

      // Disallow client deletes — games live for the duration of a duel.
      allow delete: if false;
    }
  }
}
