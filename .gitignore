# Auto Builder .gitignore
#
# Keeps the repo focused on:
#   - architecture/      (the framework)
#   - runs/{slug}/       (each build's decisions, state, history, output)
#   - top-level docs
#
# Excludes large or regenerable artifacts that would bloat the repo
# without adding meaningful version history.

# Node ecosystem
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Vendored dependencies under any plugin bundle
**/*.sdPlugin/plugin/node_modules/
**/*.sdPlugin/node_modules
**/*.sdPlugin/node_modules/

# Broken NTFS junctions left by old sandbox builds (cannot be removed via standard ops; safe to ignore)
runs/streamdock-apple-music-touchbar/output/final/com.autobuilder.applemusic-now-playing.sdPlugin/node_modules
runs/streamdock-apple-music-touchbar/output/integration/com.autobuilder.applemusic-now-playing.sdPlugin/node_modules

# Python ecosystem
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/

# Rust / Go / etc. build outputs
target/
dist/
build/
out/
*.exe
*.dll
*.dylib
*.so

# OS junk
.DS_Store
Thumbs.db
desktop.ini
*~
.directory

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace

# Logs / scratch
*.log
*.tmp
tmp/
scratch/

# Secrets — paranoia even though we don't expect them here
.env
.env.*
!.env.example
*.pem
*.key
*.p12

# Files the bash sandbox may leave around
.fuse_hidden*
.nfs*

# Large binary assets that don't belong in git
# (Add specific patterns here as builds surface them. By default everything
# else under runs/ IS tracked — the per-build decisions, charters, audits,
# and small source artifacts are the whole point.)
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# Don't ignore the snapshot dirs even though they look generated
!architecture/v*-snapshot/

# Plugin deliverables (e.g. StreamDock .sdPlugin bundles, Chrome extension packages)
# packaged as .zip under runs/{slug}/output/final/ ARE tracked — they are the
# delivered artifact for non-web-app builds. The blanket *.zip rule above still
# excludes zips elsewhere (scratch dumps, build caches, etc.).
!runs/**/output/final/*.zip

# v0.15 session debug/verification artifacts — kept locally for reference but
# excluded from git per user direction 2026-05-16. The .bat files were
# one-time tools for working around the concurrent-session FS race during
# v0.15 implementation (see codex/docs/concurrent-session-fs-race-finding.md);
# the v0.15-preview.html + v0.15-snapshots/ are visual sign-off aids that can
# be regenerated on demand from codex/topology.js. Not corpus artifacts.
/restore-index-html.bat
/apply-v0.15-dashboard.bat
/codex/v0.15-preview.html
/codex/v0.15-snapshots/
